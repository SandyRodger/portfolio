<div class="mx-auto max-w-3xl card">
  <!-- HERO -->
  <header class="card-header text-center">
    <h1 class="title">
      Alexander Rodger
    </h1>
    <p class="subtitle">
      Software Developer • Artist • Builder
    </p>

    <div class="mt-4 flex flex-wrap justify-center gap-2">
      <%= link_to "CV", cv_path, class: "btn btn-primary" %>
      <%= link_to "GitHub", "https://github.com/SandyRodger", class: "btn btn-primary", target: "_blank", rel: "noopener" %>
      <%= link_to "LinkedIn", "https://www.linkedin.com/in/alexander-rodger-742a4b141/", class: "btn btn-primary", target: "_blank", rel: "noopener" %>
    </div>

  </header>

  <!-- WORK -->
  <section id="work" class="section">
    <p class="section-title">Here are a few things I've done:</p>

      <ul class="mt-6 space-y-6">
        <!-- Launch School -->
        <li class="work-card">
          <h3 class="work-title">Launch School</h3>
          <p class="work-text">
            A mastery-based software engineering curriculum focused on 
            programming fundamentals, problem-solving, Ruby, HTTP, SQL, databases, 
            and JavaScript.  
          </p>

          <p class="work-text">
            I built several small full-stack applications during the course, 
            including a Sinatra todo manager now deployed online.
          </p>

          <div class="mt-3">
            <%= link_to "See what I studied with Launch School",
              launch_school_path, class:"btn btn-primary", target: "_blank", rel: "noopener"%>
          </div>
        </li>
  
        <!-- Writing -->
        <li class="work-card">
          <h3 class="work-title">Writing</h3>
          <p class="work-text">
            Spiegel im Spiegel in Ruby: An explanation of Arvo Pärt’s structure using loops, counters, and conditionals —
            plus my Sonic Pi implementation.
          </p>

          <div class="mt-3">
            <%= link_to "Read on Medium", "https://medium.com/@abmrodger/spiegel-im-spiegel-in-ruby-9ad13fb30cad", class: "btn btn-primary", target: "_blank", rel: "noopener" %>
          </div>
        </li>

        <!-- About / current focus -->
        <li class="work-card">
          <h3 class="work-title">What I’m focusing on</h3>
          <p class="work-text">
            Ruby on Rails, JavaScript, deployment, and building clean interfaces with Tailwind.
          </p>
        </li>
      </ul>

  </section>

  <div class="section">
    <p class="text-brand-ink-2">
      If you’re hiring, the CV link above is the best starting point.
    </p>
  </div>
</div>